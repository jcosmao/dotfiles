#!/bin/bash

label=' '
color_up='#FF7961'
color_down='#676767'

function iface_by_regex {
    ip --json link show | jq -r --arg re "$1" '.[] | select(.ifname | test($re)).ifname' | head -1
}

function vpnc_iface {
    if [[ -f /var/run/vpnc.pid || -n $(pidof nm-vpnc-service) ]]; then
        iface_by_regex '^(tun|cisco)'
    fi
}

names=()
for entry in "wg:$(iface_by_regex '^wg')" \
             "proton:$(iface_by_regex '^proton')" \
             "gp:$(iface_by_regex '^gp')" \
             "vpnc:$(vpnc_iface)"; do
    iface=${entry#*:}
    [[ -z $iface ]] && continue
    names+=("${entry%%:*}")
done

if (( ${#names[@]} == 0 )); then
    exit 0
fi

echo "$label ${names[*]}"
echo "$label"
echo "$color_up"
